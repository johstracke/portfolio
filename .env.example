# Docker Compose environment (.env)
# Use this when running services with docker compose.

# Public URLs (browser-facing)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
DIRECTUS_PUBLIC_URL=http://localhost:8055

# Directus API URL for frontend running inside Docker network
DIRECTUS_URL=http://directus:8055

# Preferred: set a static API token on the admin user in Directus (no login overhead)
DIRECTUS_STATIC_TOKEN=your_static_token_here

# Fallback auth if no static token is set
DIRECTUS_EMAIL=admin@example.com
DIRECTUS_PASSWORD=your_admin_password_here

# Database (used by postgres + directus services)
DB_USER=directus
DB_PASSWORD=your_secure_password_here
DB_NAME=directus

# Directus service secrets and initial admin
DIRECTUS_KEY=random-key-min-32-chars
DIRECTUS_SECRET=random-secret-min-32-chars
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your_admin_password_here
