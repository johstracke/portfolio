# Local Next.js development (npm run dev on host)
# Use this when PostgreSQL + Directus run in Docker, but Next.js runs on your machine.

# Site URL (for sitemap, Open Graph, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Directus CMS (host-accessible URL)
DIRECTUS_URL=http://localhost:8055
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Preferred: set a static API token on the admin user in Directus (no login overhead)
DIRECTUS_STATIC_TOKEN=your_static_token_here

# Fallback auth if no static token is set
DIRECTUS_EMAIL=admin@example.com
DIRECTUS_PASSWORD=your_admin_password_here
